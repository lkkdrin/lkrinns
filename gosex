# ==================== КЛАСС ДЛЯ СОХРАНЕНИЯ ДАННЫХ ====================
class DataManager:
    """Класс для сохранения и загрузки данных бота"""
    
    def __init__(self, data_file=DATA_FILE):
        self.data_file = data_file
        self.user_data = {}  # Данные пользователей бота
        self.user_wallets = {}  # Привязанные кошельки пользователей
        self.smart_mode_enabled = defaultdict(bool)  # Статус умного режима для пользователей
        self.mailing_history = defaultdict(list)  # История рассылок
        self.smart_mode_tasks = {}  # Задачи умного режима
        self.sessions_info = {}  # Информация о сессиях
        self.load_data()
    
    def load_data(self):
        """Загружает данные из файла"""
        if os.path.exists(self.data_file):
            try:
                with open(self.data_file, 'rb') as f:
                    data = pickle.load(f)
                    self.user_data = data.get('user_data', {})
                    self.user_wallets = data.get('user_wallets', {})
                    self.smart_mode_enabled = data.get('smart_mode_enabled', defaultdict(bool))
                    self.mailing_history = data.get('mailing_history', defaultdict(list))
                    self.sessions_info = data.get('sessions_info', {})
                logger.info(f"✅ Данные загружены из {self.data_file}")
            except Exception as e:
                logger.error(f"❌ Ошибка загрузки данных: {e}")
                self.user_data = {}
                self.user_wallets = {}
                self.smart_mode_enabled = defaultdict(bool)
                self.mailing_history = defaultdict(list)
                self.sessions_info = {}
        else:
            logger.info("📁 Файл данных не найден, создаем новые данные")
            self.user_data = {}
            self.user_wallets = {}
            self.smart_mode_enabled = defaultdict(bool)
            self.mailing_history = defaultdict(list)
            self.sessions_info = {}
    
    def save_data(self):
        """Сохраняет данные в файл"""
        try:
            data = {
                'user_data': self.user_data,
                'user_wallets': self.user_wallets,
                'smart_mode_enabled': dict(self.smart_mode_enabled),
                'mailing_history': dict(self.mailing_history),
                'sessions_info': self.sessions_info
            }
            with open(self.data_file, 'wb') as f:
                pickle.dump(data, f)
            logger.info(f"✅ Данные сохранены в {self.data_file}")
        except Exception as e:
            logger.error(f"❌ Ошибка сохранения данных: {e}")
    
    def get_user_data(self, user_id: int) -> Dict:
        """Получает данные пользователя"""
        if user_id not in self.user_data:
            self.user_data[user_id] = {
                "authenticated": False, 
                "profits": [], 
                "total_cash": 0,
                "username": None,
                "selected_session": None
            }
        return self.user_data[user_id]
    
    def update_user_data(self, user_id: int, data: Dict):
        """Обновляет данные пользователя"""
        self.user_data[user_id] = data
        self.save_data()
    
    def get_wallet(self, user_id: int) -> Optional[str]:
        """Получает кошелек пользователя"""
        return self.user_wallets.get(user_id)
    
    def set_wallet(self, user_id: int, wallet: str):
        """Устанавливает кошелек пользователя"""
        self.user_wallets[user_id] = wallet
        self.save_data()
    
    def remove_wallet(self, user_id: int):
        """Удаляет кошелек пользователя"""
        if user_id in self.user_wallets:
            del self.user_wallets[user_id]
            self.save_data()
    
    def add_profit(self, user_id: int, amount: float, profit_type: str):
        """Добавляет профит пользователю"""
        user_data = self.get_user_data(user_id)
        user_data["profits"].append({
            "amount": amount,
            "type": profit_type,
            "date": datetime.now().isoformat()
        })
        user_data["total_cash"] += amount
        self.save_data()
    
    def is_smart_mode_enabled(self, user_id: int) -> bool:
        """Проверяет, включен ли умный режим для пользователя"""
        return self.smart_mode_enabled.get(user_id, False)
    
    def set_smart_mode(self, user_id: int, enabled: bool):
        """Включает/выключает умный режим"""
        self.smart_mode_enabled[user_id] = enabled
        self.save_data()
    
    def add_mailing_history(self, user_id: int, mailing_data: Dict):
        """Добавляет запись в историю рассылок"""
        self.mailing_history[user_id].append({
            **mailing_data,
            "timestamp": datetime.now().isoformat()
        })
        self.save_data()
    
    def update_session_info(self, user_id: int, session_data: Dict):
        """Обновляет информацию о сессии"""
        self.sessions_info[user_id] = {
            **session_data,
            "last_updated": datetime.now().isoformat()
        }
        self.save_data()
    
    def get_session_info(self, user_id: int) -> Optional[Dict]:
        """Получает информацию о сессии"""
        return self.sessions_info.get(user_id)
    
    def get_selected_session(self, user_id: int) -> Optional[str]:
        """Получает выбранную сессию пользователя"""
        user_data = self.get_user_data(user_id)
        return user_data.get("selected_session")
    
    def set_selected_session(self, user_id: int, session_name: str):
        """Устанавливает выбранную сессию"""
        user_data = self.get_user_data(user_id)
        user_data["selected_session"] = session_name
        self.save_data()

# ==================== КЛАСС ДЛЯ УПРАВЛЕНИЯ РАССЫЛКОЙ ====================
class MailingManager:
    """Класс для управления рассылкой с защитой от бана"""
    
    def __init__(self):
        self.stats = {}  # user_id: {"sent": 0, "hourly": 0, "daily": 0, "last_reset": time.time()}
        self.message_templates = []  # Шаблоны сообщений для вариаций
        
    def add_message_template(self, template: str):
        """Добавляет шаблон сообщения"""
        self.message_templates.append(template)
    
    def get_message_variation(self, original_text: str) -> str:
        """Возвращает вариацию сообщения"""
        if not MESSAGE_VARIATIONS or len(self.message_templates) == 0:
            return original_text
        
        # Небольшие изменения в тексте
        variations = [
            original_text,
            original_text + " 🎁",
            "🎁 " + original_text,
            original_text.replace("!", "."),
            original_text + "\n\nПриятного дня!",
        ]
        
        return random.choice(variations)
    
    def check_limits(self, user_id: int) -> Tuple[bool, str]:
        """Проверяет лимиты на отправку"""
        now = time.time()
        
        if user_id not in self.stats:
            self.stats[user_id] = {
                "sent": 0, 
                "hourly": 0, 
                "daily": 0, 
                "last_hour_reset": now, 
                "last_day_reset": now
            }
        
        stats = self.stats[user_id]
        
        # Сброс часового счетчика
        if now - stats.get("last_hour_reset", now) > 3600:
            stats["hourly"] = 0
            stats["last_hour_reset"] = now
        
        # Сброс дневного счетчика
        if now - stats.get("last_day_reset", now) > 86400:
            stats["daily"] = 0
            stats["last_day_reset"] = now
        
        # Проверка лимитов
        if stats["hourly"] >= MAX_MESSAGES_PER_HOUR:
            return False, f"Достигнут часовой лимит ({MAX_MESSAGES_PER_HOUR} сообщений)"
        
        if stats["daily"] >= MAX_MESSAGES_PER_DAY:
            return False, f"Достигнут дневной лимит ({MAX_MESSAGES_PER_DAY} сообщений)"
        
        return True, "OK"
    
    def increment_counters(self, user_id: int):
        """Увеличивает счетчики отправки"""
        if user_id in self.stats:
            self.stats[user_id]["sent"] += 1
            self.stats[user_id]["hourly"] += 1
            self.stats[user_id]["daily"] += 1
    
    async def get_nft_gift_count(self, client: TelegramClient, user_id: int) -> int:
        """
        Получает количество NFT подарков у пользователя
        Временно используем заглушку
        """
        try:
            # Пытаемся получить информацию о пользователе
            entity = await client.get_entity(user_id)
            
            # Заглушка - возвращаем случайное число
            return random.randint(0, 10)
            
        except Exception as e:
            logger.error(f"Ошибка получения NFT подарков: {e}")
            return 0

# ==================== КЛАСС ДЛЯ СБОРА ПОЛЬЗОВАТЕЛЕЙ ИЗ ГРУПП ====================
class TrafficCollector:
    """Класс для сбора пользователей из групп Telegram"""
    
    def __init__(self):
        self.collected_users = {}  # user_id: {"group": group_name, "users": [], "premium": [], "time": time.time()}
    
    async def get_group_entity(self, client: TelegramClient, group_input: str):
        """
        Получает сущность группы по ссылке или юзернейму
        """
        try:
            # Очищаем входные данные
            group_input = group_input.strip()
            
            # Если это ссылка, извлекаем юзернейм
            if "t.me/" in group_input:
                group_input = group_input.split("t.me/")[-1].split("/")[0]
            
            # Убираем @ если есть
            if group_input.startswith("@"):
                group_input = group_input[1:]
            
            # Получаем сущность
            entity = await client.get_entity(group_input)
            
            return entity
            
        except Exception as e:
            logger.error(f"Ошибка получения группы: {e}")
            return None
    
    async def collect_users_from_group(
        self, 
        client: TelegramClient, 
        group_entity, 
        limit: int = MAX_USERS_PER_GROUP,
        premium_only: bool = PREMIUM_ONLY
    ) -> Tuple[List[str], Dict[str, int]]:
        """
        Собирает пользователей из группы (всех участников)
        Возвращает (список юзернеймов, статистика)
        """
        collected = []
        stats = {
            "total": 0,
            "premium": 0,
            "regular": 0,
            "without_username": 0
        }
        
        try:
            # Получаем участников группы
            offset = 0
            batch_size = 200  # Размер пачки для запроса
            
            while len(collected) < limit:
                try:
                    # Запрашиваем участников
                    participants = await client(GetParticipantsRequest(
                        channel=group_entity,
                        filter=ChannelParticipantsSearch(''),
                        offset=offset,
                        limit=batch_size,
                        hash=0
                    ))
                    
                    if not participants.users:
                        break
                    
                    # Обрабатываем каждого пользователя
                    for user in participants.users:
                        if isinstance(user, User) and not user.bot and not user.deleted:
                            stats["total"] += 1
                            
                            # Проверяем наличие премиума
                            is_premium = getattr(user, 'premium', False)
                            
                            if is_premium:
                                stats["premium"] += 1
                            else:
                                stats["regular"] += 1
                            
                            # Проверяем, нужно ли собирать этого пользователя
                            if premium_only and not is_premium:
                                continue
                            
                            # Получаем юзернейм
                            username = user.username
                            if username:
                                collected.append(f"@{username}")
                            else:
                                stats["without_username"] += 1
                    
                    offset += len(participants.users)
                    
                    # Задержка между запросами
                    await asyncio.sleep(COLLECTION_DELAY)
                    
                    # Если получили меньше, чем запрашивали - достигли конца
                    if len(participants.users) < batch_size:
                        break
                        
                except FloodWaitError as e:
                    wait_time = e.seconds
                    logger.warning(f"Флуд при сборе пользователей, ожидание {wait_time}с")
                    await asyncio.sleep(wait_time + 5)
                    continue
                    
                except Exception as e:
                    logger.error(f"Ошибка при сборе пользователей: {e}")
                    break
            
            # Обрезаем до лимита
            collected = collected[:limit]
            
            return collected, stats
            
        except ChatAdminRequiredError:
            logger.error("Требуются права администратора для получения списка участников")
            return [], {"error": "Требуются права администратора"}
            
        except Exception as e:
            logger.error(f"Ошибка сбора пользователей: {e}")
            return [], {"error": str(e)}
    
    async def collect_users_from_chat_messages(
        self,
        client: TelegramClient,
        chat_entity,
        limit: int = MAX_USERS_PER_GROUP,
        premium_only: bool = PREMIUM_ONLY,
        max_messages: int = MAX_MESSAGES_TO_SCAN
    ) -> Tuple[List[str], Dict[str, int]]:
        """
        Собирает пользователей из чата по истории сообщений
        (только те, кто отправлял сообщения)
        Возвращает (список юзернеймов, статистика)
        """
        collected = set()  # Используем set для уникальности
        stats = {
            "total": 0,
            "premium": 0,
            "regular": 0,
            "without_username": 0,
            "messages_scanned": 0
        }
        
        try:
            offset_id = 0
            batch_size = 100
            
            while len(collected) < limit and stats["messages_scanned"] < max_messages:
                try:
                    # Получаем историю сообщений
                    history = await client(GetHistoryRequest(
                        peer=chat_entity,
                        offset_id=offset_id,
                        offset_date=None,
                        add_offset=0,
                        limit=batch_size,
                        max_id=0,
                        min_id=0,
                        hash=0
                    ))
                    
                    if not history.messages:
                        break
                    
                    for message in history.messages:
                        stats["messages_scanned"] += 1
                        
                        # Получаем информацию об отправителе
                        if message.sender_id and message.sender_id > 0:  # Только пользователи (не каналы)
                            try:
                                user = await client.get_entity(message.sender_id)
                                
                                if isinstance(user, User) and not user.bot and not user.deleted:
                                    # Добавляем в общую статистику
                                    if user.id not in collected:
                                        stats["total"] += 1
                                        
                                        # Проверяем наличие премиума
                                        is_premium = getattr(user, 'premium', False)
                                        
                                        if is_premium:
                                            stats["premium"] += 1
                                        else:
                                            stats["regular"] += 1
                                        
                                        # Проверяем, нужно ли собирать этого пользователя
                                        if premium_only and not is_premium:
                                            continue
                                        
                                        # Получаем юзернейм
                                        username = user.username
                                        if username:
                                            collected.add(f"@{username}")
                                        else:
                                            stats["without_username"] += 1
                            except Exception as e:
                                logger.error(f"Ошибка получения информации о пользователе: {e}")
                    
                    # Обновляем offset для следующей пачки
                    offset_id = history.messages[-1].id
                    
                    # Задержка между запросами
                    await asyncio.sleep(COLLECTION_DELAY)
                    
                except FloodWaitError as e:
                    wait_time = e.seconds
                    logger.warning(f"Флуд при сборе сообщений, ожидание {wait_time}с")
                    await asyncio.sleep(wait_time + 5)
                    continue
                    
                except Exception as e:
                    logger.error(f"Ошибка при сборе сообщений: {e}")
                    break
            
            # Конвертируем set в список и обрезаем до лимита
            collected_list = list(collected)[:limit]
            
            return collected_list, stats
            
        except Exception as e:
            logger.error(f"Ошибка сбора пользователей из сообщений: {e}")
            return [], {"error": str(e)}
    
    def save_collected_users(self, user_id: int, group_name: str, users: List[str], stats: Dict, mode: str = "group"):
        """Сохраняет собранных пользователей"""
        self.collected_users[user_id] = {
            "group": group_name,
            "users": users,
            "stats": stats,
            "mode": mode,
            "time": time.time()
        }
    
    def get_collected_users(self, user_id: int) -> Optional[Dict]:
        """Получает собранных пользователей"""
        if user_id in self.collected_users:
            # Проверяем, не устарели ли данные (старше 1 часа)
            if time.time() - self.collected_users[user_id]["time"] < 3600:
                return self.collected_users[user_id]
        return None

# ==================== КЛАСС ДЛЯ УМНОГО РЕЖИМА ====================
class SmartModeManager:
    """Класс для управления умным режимом"""
    
    def __init__(self, session_manager):
        self.session_manager = session_manager
        self.active_tasks = {}  # user_id: asyncio.Task
        self.processed_messages = defaultdict(set)  # user_id: set of message_ids
    
    async def start_smart_mode(self, user_id: int, context: ContextTypes.DEFAULT_TYPE, recipients: List[str]):
        """Запускает умный режим для отслеживания ответов"""
        if user_id in self.active_tasks:
            # Останавливаем предыдущую задачу
            self.active_tasks[user_id].cancel()
        
        # Создаем новую задачу
        task = asyncio.create_task(
            self._smart_mode_worker(user_id, context, recipients)
        )
        self.active_tasks[user_id] = task
    
    async def stop_smart_mode(self, user_id: int):
        """Останавливает умный режим"""
        if user_id in self.active_tasks:
            self.active_tasks[user_id].cancel()
            del self.active_tasks[user_id]
    
    async def _smart_mode_worker(self, user_id: int, context: ContextTypes.DEFAULT_TYPE, recipients: List[str]):
        """Фоновая задача для умного режима"""
        client = await self.session_manager.load_session(user_id)
        if not client:
            return
        
        await context.bot.send_message(
            chat_id=user_id,
            text="🤖 <b>Умный режим активирован!</b>\n\nНачинаю отслеживать ответы пользователей...",
            parse_mode='HTML'
        )
        
        # Получаем сущности всех получателей
        recipient_entities = {}
        for username in recipients:
            try:
                entity = await client.get_entity(username)
                recipient_entities[username] = entity
            except:
                continue
        
        # Отслеживаем новые сообщения
        processed = set()
        
        while True:
            try:
                for username, entity in recipient_entities.items():
                    try:
                        # Получаем историю сообщений с пользователем
                        messages = await client.get_messages(entity, limit=5)
                        
                        for msg in messages:
                            if msg.id in processed:
                                continue
                            
                            # Проверяем, что сообщение от пользователя (не от нас)
                            if msg.out:
                                continue
                            
                            processed.add(msg.id)
                            
                            # Анализируем сообщение
                            await self._analyze_response(
                                user_id, context, client, username, msg
                            )
                            
                            # Задержка между ответами
                            await asyncio.sleep(random.randint(
                                SMART_MODE_RESPONSE_DELAY_MIN,
                                SMART_MODE_RESPONSE_DELAY_MAX
                            ))
                    
                    except Exception as e:
                        logger.error(f"Ошибка при проверке {username}: {e}")
                
                # Ждем перед следующей проверкой
                await asyncio.sleep(SMART_MODE_CHECK_INTERVAL)
                
            except asyncio.CancelledError:
                await context.bot.send_message(
                    chat_id=user_id,
                    text="🛑 <b>Умный режим остановлен</b>",
                    parse_mode='HTML'
                )
                break
            except Exception as e:
                logger.error(f"Ошибка в умном режиме: {e}")
                await asyncio.sleep(60)
    
    async def _analyze_response(self, user_id: int, context: ContextTypes.DEFAULT_TYPE, 
                                client: TelegramClient, username: str, message):
        """Анализирует ответ пользователя"""
        text = message.message or ""
        text_lower = text.lower()
        
        # Ищем ссылки на каналы
        channel_links = self._extract_channel_links(text, message)
        
        # Проверяем, есть ли канал в профиле
        channel_in_profile = False
        if "в профиле" in text_lower or "профиль" in text_lower:
            channel_in_profile = True
        
        # Проверяем, просит ли пользователь реакцию
        requires_reaction = any(word in text_lower for word in [
            "реакц", "комментар", "скрин", "подпис", "лайк"
        ])
        
        # Логика обработки
        if channel_links or channel_in_profile:
            # Пользователь дал канал - подписываемся
            await self._handle_channel_response(
                user_id, context, client, username, channel_links, requires_reaction
            )
        else:
            # Просто уведомляем, что ответ получен
            await context.bot.send_message(
                chat_id=user_id,
                text=f"💬 <b>@{username}</b> - ответил(а):\n\n{text[:100]}...",
                parse_mode='HTML'
            )
    
    def _extract_channel_links(self, text: str, message) -> List[str]:
        """Извлекает ссылки на каналы из сообщения"""
        links = []
        
        # Ищем ссылки в тексте
        url_pattern = r'(?:https?://)?(?:t\.me/|telegram\.me/)([a-zA-Z0-9_]+)'
        matches = re.findall(url_pattern, text)
        for match in matches:
            links.append(f"https://t.me/{match}")
        
        # Ищем ссылки в сущностях сообщения
        if message.entities:
            for entity in message.entities:
                if hasattr(entity, 'url') and entity.url:
                    links.append(entity.url)
        
        return links
    
    async def _handle_channel_response(self, user_id: int, context: ContextTypes.DEFAULT_TYPE,
                                       client: TelegramClient, username: str, 
                                       channel_links: List[str], requires_reaction: bool):
        """Обрабатывает ответ с каналом"""
        
        # Подписываемся на каналы
        subscribed = []
        failed = []
        
        for link in channel_links:
            try:
                # Получаем сущность канала
                channel = await client.get_entity(link)
                
                # Подписываемся
                await client(JoinChannelRequest(channel))
                subscribed.append(link)
                
                # Отправляем отчет
                await context.bot.send_message(
                    chat_id=user_id,
                    text=f"✅ @{username} - подписался на {link}",
                    parse_mode='HTML'
                )
                
            except Exception as e:
                failed.append(link)
                logger.error(f"Ошибка подписки на {link}: {e}")
        
        if subscribed:
            # Отправляем ответ пользователю
            await asyncio.sleep(random.randint(
                SMART_MODE_RESPONSE_DELAY_MIN,
                SMART_MODE_RESPONSE_DELAY_MAX
            ))
            
            try:
                entity = await client.get_entity(username)
                
                if requires_reaction:
                    await client.send_message(
                        entity,
                        "Я подписалась на ваш канал. Ожидаю вашу заявку на подписку на мой канал. Отправьте скрин, пожалуйста."
                    )
                    
                    await context.bot.send_message(
                        chat_id=user_id,
                        text=f"⚠️ @{username} - требуется реакция (скрин подписки)",
                        parse_mode='HTML'
                    )
                else:
                    await client.send_message(
                        entity,
                        "Я подписалась, жду твою заявку на подписку на канал. Скинь скрин пожалуйста, что кинули заявку."
                    )
                    
                    await context.bot.send_message(
                        chat_id=user_id,
                        text=f"✅ @{username} - ожидание скрина подписки",
                        parse_mode='HTML'
                    )
            except Exception as e:
                logger.error(f"Ошибка отправки ответа {username}: {e}")
        
        if failed:
            await context.bot.send_message(
                chat_id=user_id,
                text=f"❌ @{username} - не удалось подписаться на {', '.join(failed)}",
                parse_mode='HTML'
            )

# ==================== КЛАСС ДЛЯ ПРОВЕРКИ ТЕНЕВОГО БАНА ====================
class ShadowBanChecker:
    """Класс для проверки теневого/спам бана"""
    
    def __init__(self, session_manager):
        self.session_manager = session_manager
    
    async def check_shadow_ban(self, user_id: int, context: ContextTypes.DEFAULT_TYPE) -> Dict[str, Any]:
        """Проверяет наличие теневого/спам бана"""
        result = {
            "spam_bot": False,
            "spam_bot_message": "",
            "shadow_ban": False,
            "details": ""
        }
        
        client = await self.session_manager.load_session(user_id)
        if not client:
            result["details"] = "❌ Сессия не загружена"
            return result
        
        try:
            # Шаг 1: Проверка через @SpamBot
            spam_bot_result = await self._check_spam_bot(client)
            result["spam_bot"] = spam_bot_result["is_banned"]
            result["spam_bot_message"] = spam_bot_result["message"]
            
            # Шаг 2: Проверка теневого бана (отправка сообщения тестовому пользователю)
            shadow_ban_result = await self._check_shadow_ban_send(client)
            result["shadow_ban"] = shadow_ban_result["is_banned"]
            
            if not result["shadow_ban"]:
                # Очищаем переписку с тестовым пользователем
                await self._clear_chat_with_user(client, TEST_USER)
            
            # Формируем детали
            result["details"] = self._format_result(result)
            
        except Exception as e:
            logger.error(f"Ошибка при проверке бана: {e}")
            result["details"] = f"❌ Ошибка проверки: {str(e)}"
        
        return result
    
    async def _check_spam_bot(self, client: TelegramClient) -> Dict[str, Any]:
        """Проверяет статус через @SpamBot"""
        result = {
            "is_banned": False,
            "message": ""
        }
        
        try:
            # Получаем сущность SpamBot
            spam_bot = await client.get_entity(SPAM_BOT_USERNAME)
            
            # Отправляем /start
            await client.send_message(spam_bot, "/start")
            
            # Ждем ответа
            await asyncio.sleep(3)
            
            # Получаем последнее сообщение от бота
            messages = await client.get_messages(spam_bot, limit=1)
            
            if messages:
                msg_text = messages[0].message
                result["message"] = msg_text
                
                # Анализируем сообщение
                # Если сообщение длинное - скорее всего есть бан
                if len(msg_text) > 200:
                    result["is_banned"] = True
                else:
                    result["is_banned"] = False
            
            # Отправляем второй /start для завершения диалога
            await client.send_message(spam_bot, "/start")
            
        except Exception as e:
            logger.error(f"Ошибка при проверке SpamBot: {e}")
            result["message"] = f"Ошибка: {str(e)}"
        
        return result
    
    async def _check_shadow_ban_send(self, client: TelegramClient) -> Dict[str, Any]:
        """Проверяет теневой бан отправкой сообщения"""
        result = {
            "is_banned": False
        }
        
        try:
            # Получаем сущность тестового пользователя
            test_user = await client.get_entity(TEST_USER)
            
            # Пробуем отправить сообщение
            await client.send_message(test_user, ".")
            
            # Если дошли сюда - сообщение отправилось (нет теневого бана)
            result["is_banned"] = False
            
        except Exception as e:
            # Если ошибка - возможно теневой бан
            error_str = str(e).lower()
            if "cannot send" in error_str or "forbidden" in error_str or "flood" in error_str:
                result["is_banned"] = True
            else:
                # Другие ошибки (например, пользователь не найден) не считаем баном
                result["is_banned"] = False
        
        return result
    
    async def _clear_chat_with_user(self, client: TelegramClient, username: str):
        """Очищает переписку с пользователем"""
        try:
            user = await client.get_entity(username)
            
            # Получаем историю сообщений
            messages = await client.get_messages(user, limit=100)
            
            # Удаляем сообщения
            for msg in messages:
                if msg.out:  # Только наши сообщения
                    try:
                        await msg.delete()
                    except:
                        pass
                
                await asyncio.sleep(0.5)
            
        except Exception as e:
            logger.error(f"Ошибка при очистке чата с {username}: {e}")
    
    def _format_result(self, result: Dict[str, Any]) -> str:
        """Форматирует результат проверки"""
        lines = []
        
        # Результат SpamBot
        if result["spam_bot"]:
            lines.append("🚫 <b>СПАМ БОТ:</b> ОБНАРУЖЕН!")
        else:
            lines.append("✅ <b>СПАМ БОТ:</b> не обнаружен")
        
        # Результат теневого бана
        if result["shadow_ban"]:
            lines.append("🚫 <b>ТЕНЕВОЙ БАН:</b> ОБНАРУЖЕН!")
        else:
            lines.append("✅ <b>ТЕНЕВОЙ БАН:</b> не обнаружен")
        
        # Сообщение от SpamBot
        if result["spam_bot_message"]:
            short_msg = result["spam_bot_message"][:200] + "..." if len(result["spam_bot_message"]) > 200 else result["spam_bot_message"]
            lines.append(f"\n📝 <b>Сообщение от @SpamBot:</b>\n{short_msg}")
        
        return "\n".join(lines)

