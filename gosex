async def traffic_group_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик отправки ссылки на группу для сбора пользователей (всех участников)"""
    user_id = update.effective_user.id
    group_input = update.message.text.strip()
    
    if group_input.lower() == 'отмена':
        context.user_data['waiting_for_group'] = False
        await update.message.reply_text("❌ Операция отменена")
        await show_main_menu(update, context)
        return ConversationHandler.END
    
    # Получаем клиент
    client = await session_manager.load_session(user_id)
    
    if not client:
        await update.message.reply_text("❌ Сессия не загружена")
        return ConversationHandler.END
    
    # Отправляем сообщение о начале сбора
    status_msg = await update.message.reply_text(
        f"🔄 Начинаю сбор пользователей из группы: {group_input}\n"
        f"Режим: сбор ВСЕХ участников группы\n"
        f"Только Premium: {'✅' if PREMIUM_ONLY else '❌'}\n"
        f"Максимум: {MAX_USERS_PER_GROUP} пользователей\n"
        f"Это может занять некоторое время..."
    )
    
    try:
        # Получаем сущность группы
        group_entity = await session_manager.traffic_collector.get_group_entity(client, group_input)
        
        if not group_entity:
            await status_msg.edit_text(
                "❌ Не удалось найти группу.\n"
                "Проверьте ссылку и убедитесь, что аккаунт состоит в этой группе."
            )
            return ConversationHandler.END
        
        # Собираем пользователей (всех участников)
        users, stats = await session_manager.traffic_collector.collect_users_from_group(
            client, 
            group_entity,
            limit=MAX_USERS_PER_GROUP,
            premium_only=PREMIUM_ONLY
        )
        
        if "error" in stats:
            await status_msg.edit_text(f"❌ Ошибка: {stats['error']}")
            return ConversationHandler.END
        
        # Сохраняем результат
        group_name = getattr(group_entity, 'title', str(group_entity.id))
        session_manager.traffic_collector.save_collected_users(user_id, group_name, users, stats, mode="group")
        
        # Формируем отчет
        premium_count = len(users)
        
        report = (
            f"✅ <b>Сбор пользователей (участников группы) завершен!</b>\n\n"
            f"Группа: {group_name}\n"
            f"Всего участников: {stats['total']}\n"
            f"Premium аккаунтов: {stats['premium']}\n"
            f"Обычных аккаунтов: {stats['regular']}\n"
