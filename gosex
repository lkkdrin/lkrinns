async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /start"""
    user_id = update.effective_user.id
    username = update.effective_user.username
    
    # Получаем данные пользователя
    user_data = data_manager.get_user_data(user_id)
    user_data["username"] = username
    data_manager.update_user_data(user_id, user_data)
    
    # Если пользователь уже аутентифицирован, показываем меню
    if user_data.get("authenticated", False):
        await show_main_menu(update, context)
        return ConversationHandler.END
    
    # Запрашиваем пароль
    await update.message.reply_text("🔒 Введите пароль для доступа к боту:")
    return ENTER_PASSWORD

async def check_password(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Проверка пароля"""
    user_id = update.effective_user.id
    
    if update.message.text == ADMIN_PASSWORD:
        user_data = data_manager.get_user_data(user_id)
        user_data["authenticated"] = True
        data_manager.update_user_data(user_id, user_data)
        
        # Отправляем эмодзи
        await update.message.reply_text("✅")
        
        # Очищаем чат (удаляем предыдущие сообщения)
        chat_id = update.effective_chat.id
        try:
            # Удаляем сообщение с паролем
            await update.message.delete()
            
            # Пытаемся удалить предыдущие сообщения (ограничение Telegram - не старше 48 часов)
            for i in range(1, 10):
                try:
                    await context.bot.delete_message(chat_id=chat_id, message_id=update.message.message_id - i)
                except:
                    pass
        except:
            pass
        
        # Отправляем видео
        await send_video_safe(update, VIDEO_PATH)
        
        # Показываем главное меню
        await show_main_menu(update, context)
        return ConversationHandler.END
    else:
        await update.message.reply_text("❌ Неверный пароль. Попробуйте /start")
        return ConversationHandler.END

