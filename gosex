            parse_mode='HTML'
        )
        await session_manager.close_session(user_id)
        return ConversationHandler.END
        
    else:
        # Если не удалось, пробуем еще раз проверить статус без пароля
        await asyncio.sleep(2)
        client, status = await session_manager.check_qr_login(user_id)
        
