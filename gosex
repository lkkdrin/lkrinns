async def send_video_safe(update: Update, video_path: str) -> bool:
    """
    Безопасная отправка видео с обработкой ошибок
    """
    if not os.path.exists(video_path):
        logger.warning(f"⚠️ Видео файл не найден: {video_path}")
        await update.message.reply_text("✅ Авторизация успешна!")
        return False
    
    # Проверяем размер файла
    file_size = os.path.getsize(video_path)
    if file_size > MAX_VIDEO_SIZE:
        logger.warning(f"⚠️ Видео файл слишком большой ({file_size} байт)")
        await update.message.reply_text("✅ Авторизация успешна!")
        return False
    
    try:
        # Пробуем отправить видео с таймаутом
        with open(video_path, 'rb') as video:
            await update.message.reply_video(
                video=video,
                read_timeout=VIDEO_TIMEOUT,
                write_timeout=VIDEO_TIMEOUT,
                connect_timeout=VIDEO_TIMEOUT
            )
        return True
    except (TimedOut, NetworkError) as e:
        logger.error(f"❌ Таймаут при отправке видео: {e}")
        await update.message.reply_text("✅ Авторизация успешна!")
        return False
    except Exception as e:
        logger.error(f"❌ Ошибка при отправке видео: {e}")
        await update.message.reply_text("✅ Авторизация успешна!")
        return False

