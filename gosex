async def mailing_usernames(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Запуск рассылки"""
    text = update.message.text.strip()
    
    if text.lower() == 'отмена':
        await update.message.reply_text("❌ Рассылка отменена")
        return ConversationHandler.END
    
    # Парсим юзернеймы
    usernames = re.findall(r'@(\w+)', text)
    
    if not usernames:
        await update.message.reply_text("❌ Нет юзернеймов. Попробуйте снова:")
        return MAILING_USERNAMES
    
    user_id = update.effective_user.id
    message_text = context.user_data['mailing_text']
    mailing_mode = context.user_data.get('mailing_mode', 'normal')
    
    # Сохраняем получателей для умного режима
    context.user_data['last_mailing_recipients'] = usernames
    
    # Проверяем сессию
    client = await session_manager.load_session(user_id)
    
    if not client:
        await update.message.reply_text("❌ Сессия не загружена")
        return ConversationHandler.END
    
    mode_text = "NFT (1-5 подарков)" if mailing_mode == "nft" else "обычный"
    
    # Стартуем рассылку
    await update.message.reply_text(
        f"📨 <b>Запуск рассылки</b>\n\n"
        f"Режим: {mode_text}\n"
        f"Всего получателей: {len(usernames)}\n"
        f"Будут обработаны с защитой от флуда...",
        parse_mode='HTML'
    )
    
    # Результаты
    results = {
        'success': 0, 
        'failed': 0, 
        'blocked': 0,
        'deactivated': 0, 
        'flood_wait': 0, 
        'nft_skipped': 0,
        'details': []
    }
    
    status_msg = await update.message.reply_text("🔄 Подготовка к рассылке...")
    
    for i, username in enumerate(usernames):
        # Обновляем статус
        progress = int(i / len(usernames) * 100)
        await status_msg.edit_text(
            f"🔄 Прогресс: {progress}% | Успешно: {results['success']} | Пропущено: {results['failed'] + results['nft_skipped']}"
        )
        
        # Отправляем сообщение с защитой
        success, status = await session_manager.send_safe_message(user_id, username, message_text, mailing_mode)
        
        if success:
            results['success'] += 1
            results['details'].append(f"✅ @{username} - успешно")
        else:
            if "NFT" in status:
                results['nft_skipped'] += 1
                results['details'].append(f"⏭ @{username} - {status}")
            elif "флуд" in status.lower():
                results['flood_wait'] += 1
                results['details'].append(f"⚠️ @{username} - {status}")
            elif "заблокировал" in status:
                results['blocked'] += 1
                results['details'].append(f"❌ @{username} - {status}")
            elif "удален" in status:
                results['deactivated'] += 1
                results['details'].append(f"❌ @{username} - {status}")
            else:
                results['failed'] += 1
                results['details'].append(f"❌ @{username} - {status}")
        
        # Задержка между сообщениями (кроме последнего)
        if i < len(usernames) - 1:
            # Каждые BATCH_SIZE сообщений делаем большую паузу
            if (i + 1) % BATCH_SIZE == 0:
                pause_msg = await update.message.reply_text(
                    f"⏱ Пауза после {BATCH_SIZE} сообщений на {BATCH_PAUSE} секунд..."
                )
                await asyncio.sleep(BATCH_PAUSE)
                await pause_msg.delete()
            else:
                # Обычная случайная задержка
                delay = random.randint(MIN_DELAY_BETWEEN_MESSAGES, MAX_DELAY_BETWEEN_MESSAGES)
                await asyncio.sleep(delay)
    
    # Финальный прогресс
    await status_msg.edit_text(f"🔄 Прогресс: 100% | Завершено!")
    
    # Получаем статистику
    stats = session_manager.mailing_manager.stats.get(user_id, {"sent": 0, "hourly": 0, "daily": 0})
    
    # Отчет
    report = (
        f"📊 <b>Отчет о рассылке</b>\n\n"
        f"Режим: {mode_text}\n"
        f"✅ Успешно: {results['success']}\n"
        f"⏭ Пропущено (NFT > {MAX_NFT_GIFTS}): {results['nft_skipped']}\n"
        f"❌ Неудачно: {results['failed']}\n"
        f"🚫 Заблокировали: {results['blocked']}\n"
        f"💀 Удалены: {results['deactivated']}\n"
        f"⏱ Флуд: {results['flood_wait']}\n\n"
        f"📈 <b>Статистика аккаунта:</b>\n"
        f"Всего отправлено: {stats['sent']}\n"
        f"Отправлено за час: {stats['hourly']}/{MAX_MESSAGES_PER_HOUR}\n"
        f"Отправлено за день: {stats['daily']}/{MAX_MESSAGES_PER_DAY}\n\n"
    )
    
    if results['details']:
        report += "<b>Детали (первые 15):</b>\n"
        for detail in results['details'][:15]:
            report += f"{detail}\n"
        
        if len(results['details']) > 15:
            report += f"... и еще {len(results['details']) - 15}"
    
    await update.message.reply_text(report, parse_mode='HTML')
    
    # Если режим обычный, предлагаем включить умный режим
    if mailing_mode == "normal" and results['success'] > 0:
        await update.message.reply_text(
            "💡 Хотите включить умный режим для отслеживания ответов?",
            reply_markup=get_smart_mode_button()
        )
    
    # Возвращаемся в меню
    context.user_data.clear()
    await show_main_menu(update, context)
    return ConversationHandler.END

