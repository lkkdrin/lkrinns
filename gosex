async def two_fa_password_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик ввода пароля 2FA"""
    user_id = update.effective_user.id
    password = update.message.text
    
    if password.lower() == 'отмена':
        await session_manager.close_session(user_id)
        await update.message.reply_text("❌ Вход отменен")
        await show_main_menu(update, context)
        return ConversationHandler.END
    
    # Отправляем сообщение о проверке
    status_msg = await update.message.reply_text("🔄 Проверка пароля...")
    
    # Пытаемся войти с паролем
    client, status = await session_manager.check_qr_login(user_id, password)
    
    await status_msg.delete()
    
    if status == 'success' and client:
        me = await client.get_me()
        await update.message.reply_text(
            f"✅ <b>Успешный вход с 2FA!</b>\n\n"
            f"Аккаунт: @{me.username} (ID: {me.id})\n"
            f"Сессия сохранена в папке sessions/",
            parse_mode='HTML'
        )
        await show_main_menu(update, context)
