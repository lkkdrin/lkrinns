            )

async def two_fa_password_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик ввода пароля 2FA"""
    user_id = update.effective_user.id
    password = update.message.text
    
    if password.lower() == 'отмена':
        await session_manager.close_session(user_id)
        await update.message.reply_text("❌ Вход отменен")
        await show_main_menu(update, context)
        return ConversationHandler.END
    
    # Отправляем сообщение о проверке
    status_msg = await update.message.reply_text("🔄 Проверка пароля...")
    
    # Пытаемся войти с паролем
    client, status = await session_manager.check_qr_login(user_id, password)
    
    await status_msg.delete()
    
    if status == 'success' and client:
        me = await client.get_me()
        await update.message.reply_text(
            f"✅ <b>Успешный вход с 2FA!</b>\n\n"
            f"Аккаунт: @{me.username} (ID: {me.id})\n"
            f"Сессия сохранена в папке sessions/",
            parse_mode='HTML'
        )
        await show_main_menu(update, context)
        return ConversationHandler.END
        
    elif status == 'wrong_password':
        await update.message.reply_text(
            "❌ <b>Неверный пароль</b>\n\n"
            "Попробуйте снова или отправьте 'отмена' для выхода:",
            parse_mode='HTML',
            reply_markup=get_2fa_menu_keyboard()
        )
        return TWO_FA_PASSWORD
        
    elif status == 'expired':
        await update.message.reply_text(
            "❌ <b>Срок действия QR-кода истек</b>\n\n"
            "Нажмите 'QR-вход' снова, чтобы получить новый код.",
            parse_mode='HTML'
        )
        await session_manager.close_session(user_id)
        return ConversationHandler.END
        
    else:
        # Если не удалось, пробуем еще раз проверить статус без пароля
        await asyncio.sleep(2)
        client, status = await session_manager.check_qr_login(user_id)
        
        if status == 'success' and client:
            me = await client.get_me()
            await update.message.reply_text(
                f"✅ <b>Успешный вход!</b>\n\n"
                f"Аккаунт: @{me.username}",
                parse_mode='HTML'
            )
            await show_main_menu(update, context)
            return ConversationHandler.END
        else:
            await update.message.reply_text(
                "❌ <b>Ошибка входа</b>\n\n"
                "Попробуйте снова через QR-вход.\n\n"
                "Убедитесь, что:\n"
                "1️⃣ Вы отсканировали QR-код\n"
                "2️⃣ Ввели правильный пароль 2FA в телефоне\n"
                "3️⃣ Подождали несколько секунд",
                parse_mode='HTML'
            )
            await session_manager.close_session(user_id)
            return ConversationHandler.END

async def check_qr_login_task(user_id: int, context: ContextTypes.DEFAULT_TYPE):
    """Фоновая задача для проверки QR-входа"""
    for i in range(30):  # Проверяем 30 раз (каждые 2 секунды = 60 секунд)
        await asyncio.sleep(2)
        
        client, status = await session_manager.check_qr_login(user_id)
        
        if status == 'success' and client:
            me = await client.get_me()
            try:
                await context.bot.send_message(
                    chat_id=user_id,
                    text=(
                        f"✅ <b>Успешный вход!</b>\n\n"
                        f"Аккаунт: @{me.username} (ID: {me.id})\n"
                        f"Сессия сохранена в папке sessions/"
                    ),
                    parse_mode='HTML'
                )
            except:
                pass
            break
        elif status == '2fa':
            try:
                await context.bot.send_message(
                    chat_id=user_id,
                    text=(
                        "🔐 <b>Требуется двухфакторная аутентификация</b>\n\n"
                        "Введите ваш облачный пароль в Telegram на телефоне,\n"
                        "затем нажмите 'Проверить вход'."
                    ),
                    parse_mode='HTML'
                )
            except:
                pass
            break

