# Функция для загрузки готовой сессии
async def load_existing_session(user_id):
    """Загружает готовую сессию из файла, если она существует"""
    session_file = f"{SESSIONS_DIR}/{user_id}.session"
    
    if os.path.exists(session_file):
        try:
            client = TelegramClient(session_file, API_ID, API_HASH)
            await client.connect()
            
            if await client.is_user_authorized():
                logger.info(f"✅ Готовая сессия загружена для user_id: {user_id}")
                return client
            else:
                logger.warning(f"⚠️ Сессия существует, но не авторизована: {user_id}")
                await client.disconnect()
                return None
        except Exception as e:
            logger.error(f"❌ Ошибка загрузки сессии: {e}")
            return None
    return None

