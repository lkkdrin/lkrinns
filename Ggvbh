async def mailing_usernames(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получение списка юзернеймов и запуск рассылки"""
    text = update.message.text.strip()
    
    if text.lower() == 'отмена':
        await update.message.reply_text("❌ Рассылка отменена")
        return ConversationHandler.END
    
    # Парсим юзернеймы
    usernames = re.findall(r'@(\w+)', text)
    
    if not usernames:
        await update.message.reply_text(
            "❌ Не найдено ни одного юзернейма. Попробуйте снова:"
        )
        return MAILING_USERNAMES
    
    user_id = update.effective_user.id
    message_text = context.user_data['mailing_text']
    
    if user_id not in user_sessions:
        await update.message.reply_text(
            "❌ Сессия не найдена. Начните процесс заново через кнопку 'Рассылка'."
        )
        return ConversationHandler.END
    
    client = user_sessions[user_id]["client"]
    
    # Проверяем, авторизован ли клиент
    if not await client.is_user_authorized():
        await update.message.reply_text(
            "❌ Сессия не авторизована. Подключите аккаунт заново через кнопку 'Рассылка'."
        )
        return ConversationHandler.END
    
    await update.message.reply_text(
        f"📨 <b>Запуск рассылки</b>\n\n"
        f"Всего получателей: {len(usernames)}\n"
        f"Текст: {message_text[:50]}{'...' if len(message_text) > 50 else ''}\n\n"
        f"Рассылка началась...",
        parse_mode='HTML'
    )
    
    # Запускаем рассылку
    results = {
        'success': 0,
        'failed': 0,
        'blocked': 0,
        'deactivated': 0,
        'flood_wait': 0,
        'details': []
    }
    
    status_message = await update.message.reply_text("🔄 Прогресс: 0%")
    
    for i, username in enumerate(usernames):
        try:
            # Пытаемся получить пользователя по юзернейму
            try:
                entity = await client.get_entity(username)
            except ValueError:
                results['failed'] += 1
                results['details'].append(f"❌ @{username} - неверный юзернейм")
                continue
            
            # Отправляем сообщение
            await client.send_message(entity, message_text)
            
            results['success'] += 1
            results['details'].append(f"✅ @{username} - успешно")
            
        except FloodWaitError as e:
            wait_time = e.seconds
            results['flood_wait'] += 1
            results['details'].append(f"⚠️ @{username} - флуд-контроль, ожидание {wait_time}с")
            
            # Отправляем уведомление о флуд-контроле
            if i % 10 == 0:
                await update.message.reply_text(
                    f"⚠️ Обнаружен флуд-контроль. Ожидание {wait_time} секунд..."
                )
            
            await asyncio.sleep(wait_time)
            
        except Exception as e:
            error_str = str(e)
            if "USER_IS_BLOCKED" in error_str:
                results['blocked'] += 1
                results['details'].append(f"❌ @{username} - пользователь заблокировал аккаунт")
            elif "USER_IS_DEACTIVATED" in error_str:
                results['deactivated'] += 1
                results['details'].append(f"❌ @{username} - аккаунт удален")
            else:
                results['failed'] += 1
                results['details'].append(f"❌ @{username} - ошибка: {error_str[:50]}")
        
        # Обновляем прогресс
        if (i + 1) % 5 == 0 or i == len(usernames) - 1:
            progress = int((i + 1) / len(usernames) * 100)
            await status_message.edit_text(f"🔄 Прогресс: {progress}%")
    
    # Формируем отчет
    report = (
        f"📊 <b>Отчет о рассылке</b>\n\n"
        f"✅ Успешно: {results['success']}\n"
        f"❌ Неудачно: {results['failed']}\n"
        f"🚫 Заблокировали: {results['blocked']}\n"
        f"💀 Аккаунты удалены: {results['deactivated']}\n"
        f"⏱ Флуд-контроль: {results['flood_wait']}\n\n"
    )
    
    # Добавляем детали (первые 15)
    if results['details']:
        report += "<b>Детали (первые 15):</b>\n"
        for detail in results['details'][:15]:
            report += f"{detail}\n"
        
        if len(results['details']) > 15:
            report += f"... и еще {len(results['details']) - 15}"
    
    await update.message.reply_text(report, parse_mode='HTML')
    
    # Очищаем временные данные
    context.user_data.clear()
    
    # Возвращаемся в главное меню
    await show_main_menu(update, context)
    return ConversationHandler.END

async def add_profit(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Команда для добавления профита"""
    user_id = update.effective_user.id
    
    if not user_data.get(user_id, {}).get("authenticated", False):
        await update.message.reply_text("❌ Вы не авторизованы")
        return
    
    try:
        amount = int(context.args[0])
        user_data[user_id]["profits"].append(amount)
        user_data[user_id]["total_cash"] += amount
        await update.message.reply_text(f"✅ Профит {amount} руб. добавлен!")
    except (IndexError, ValueError):
        await update.message.reply_text("Использование: /profit [сумма]")

async def get_my_id(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Команда для получения своего user_id"""
    user_id = update.effective_user.id
    await update.message.reply_text(f"🆔 Ваш user_id: <code>{user_id}</code>", parse_mode='HTML')

async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Отмена текущего действия"""
    await update.message.reply_text("❌ Действие отменено")
    return ConversationHandler.END

async def mailing_cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Отмена рассылки"""
    user_id = update.effective_user.id
    
    # Закрываем клиент, если он есть
    if user_id in user_sessions:
        try:
            await user_sessions[user_id]["client"].disconnect()
        except:
            pass
    
    await update.message.reply_text("❌ Рассылка отменена")
    return ConversationHandler.END

def main():
    """Запуск бота"""
    # Проверяем наличие API_ID и API_HASH
    if API_ID == 12345 or API_HASH == "your_api_hash_here":
        print("⚠️ ВНИМАНИЕ: Не забудьте указать API_ID и API_HASH!")
        print("Получить их можно на https://my.telegram.org")
    
    application = Application.builder().token(BOT_TOKEN).build()
    
    # ConversationHandler для авторизации в боте
    auth_conv_handler = ConversationHandler(
        entry_points=[CommandHandler('start', start)],
        states={
            ENTER_PASSWORD: [MessageHandler(filters.TEXT & ~filters.COMMAND, check_password)],
        },
        fallbacks=[CommandHandler('cancel', cancel)],
    )
    
    # ConversationHandler для рассылки
    mailing_conv_handler = ConversationHandler(
        entry_points=[CallbackQueryHandler(button_handler, pattern='^mailing$')],
        states={
            MAILING_PHONE: [MessageHandler(filters.TEXT & ~filters.COMMAND, mailing_phone)],
            MAILING_CODE: [MessageHandler(filters.TEXT & ~filters.COMMAND, mailing_code)],
            MAILING_PASSWORD: [MessageHandler(filters.TEXT & ~filters.COMMAND, mailing_password)],
            MAILING_MESSAGE: [MessageHandler(filters.TEXT & ~filters.COMMAND, mailing_message)],
            MAILING_USERNAMES: [MessageHandler(filters.TEXT & ~filters.COMMAND, mailing_usernames)],
        },
        fallbacks=[CommandHandler('cancel', mailing_cancel)],
        allow_reentry=True,
    )
    
    application.add_handler(auth_conv_handler)
    application.add_handler(mailing_conv_handler)
    application.add_handler(CallbackQueryHandler(button_handler))
    application.add_handler(CommandHandler("profit", add_profit))
    application.add_handler(CommandHandler("myid", get_my_id))  # Команда для получения ID
    
    print("🚀 Бот запущен...")
    print(f"📁 Сессии будут сохраняться в папке: {SESSIONS_DIR}")
    print("💡 Используйте команду /myid чтобы узнать свой user_id")
    application.run_polling(allowed_updates=Update.ALL_TYPES)

if __name__ == '__main__':
    main()
