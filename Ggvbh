async def mailing_phone(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получение номера телефона для авторизации"""
    phone = update.message.text
    user_id = update.effective_user.id
    
    # Проверяем формат номера
    if not re.match(r'^\+?\d{10,15}$', phone.replace(' ', '')):
        await update.message.reply_text(
            "❌ Неверный формат номера.\n"
            "Введите номер в международном формате (например, +79001234567):"
        )
        return MAILING_PHONE
    
    # Проверяем, есть ли уже сохраненная сессия
    session_file = f"{SESSIONS_DIR}/{user_id}.session"
    
    # Удаляем старую сессию, если она есть (для чистой авторизации)
    if os.path.exists(session_file):
        os.remove(session_file)
        await update.message.reply_text("🔄 Удалена старая сессия. Начинаем новую авторизацию...")
    
    # Создаем клиента с информацией об устройстве
    client = TelegramClient(
        session_file, 
        API_ID, 
        API_HASH,
        device_model="Python Worker Bot",
        system_version="4.16.30-vxCUSTOM",
        app_version="1.0.0",
        lang_code="ru",
        system_lang_code="ru"
    )
    
    await client.connect()
    
    try:
        # Отправляем запрос кода с пустыми настройками
        result = await client(functions.auth.SendCodeRequest(
            phone_number=phone,
            api_id=API_ID,
            api_hash=API_HASH,
            settings=CodeSettings()
        ))
        
        # Определяем тип доставки кода
        sent_code_type = result.type
        timeout = result.timeout
        
        delivery_info = "📱 Код должен прийти "
        if hasattr(sent_code_type, '_classname'):
            if "Sms" in sent_code_type._classname:
                delivery_info += "по SMS на ваш номер"
            elif "App" in sent_code_type._classname:
                delivery_info += "в официальное приложение Telegram (в чат с аккаунтом Telegram)"
            elif "Call" in sent_code_type._classname:
                delivery_info += "через звонок (автоматический голосовой вызов)"
            else:
                delivery_info += f"неизвестным способом ({sent_code_type._classname})"
        
        # Сохраняем данные
        context.user_data['phone_code_hash'] = result.phone_code_hash
        context.user_data['phone_number'] = phone
        
        user_sessions[user_id] = {
            "client": client, 
            "phone": phone, 
            "session_file": session_file,
            "phone_code_hash": result.phone_code_hash
        }
        
        await update.message.reply_text(
            f"📱 <b>Запрос кода отправлен!</b>\n\n"
            f"{delivery_info}\n"
            f"Таймаут: {timeout} сек\n\n"
            f"⚠️ Если код не приходит в течение 2-3 минут, проверьте оба способа (SMS и приложение).\n\n"
            f"📲 <b>Введите полученный код (только цифры):</b>",
            parse_mode='HTML'
        )
        return MAILING_CODE
        
    except PhoneNumberFloodError:
        await update.message.reply_text(
            "❌ <b>Слишком много попыток запроса кода</b>\n\n"
            "Telegram временно заблокировал запросы для этого номера.\n"
            "Подождите несколько часов (обычно 2-4 часа) и попробуйте снова.",
            parse_mode='HTML'
        )
        await client.disconnect()
        return ConversationHandler.END
        
    except PhoneNumberBannedError:
        await update.message.reply_text(
            "❌ <b>Номер заблокирован</b>\n\n"
            "Этот номер был заблокирован Telegram.\n"
            "Используйте другой номер телефона.",
            parse_mode='HTML'
        )
        await client.disconnect()
        return ConversationHandler.END
        
    except Exception as e:
        await update.message.reply_text(
            f"❌ <b>Ошибка при запросе кода</b>\n\n"
            f"Текст ошибки: {str(e)}\n\n"
            f"Попробуйте позже или используйте другой номер.",
            parse_mode='HTML'
        )
        await client.disconnect()
        return ConversationHandler.END

async def mailing_code(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получение кода подтверждения"""
    code = update.message.text.strip()
    user_id = update.effective_user.id
    
    # Убираем все нецифровые символы из кода
    code = re.sub(r'\D', '', code)
    
    if not code or len(code) < 4:
        await update.message.reply_text(
            "❌ Неверный формат кода. Введите код (только цифры):"
        )
        return MAILING_CODE
    
    if user_id not in user_sessions:
        await update.message.reply_text(
            "❌ Сессия не найдена. Начните процесс заново через кнопку 'Рассылка'."
        )
        return ConversationHandler.END
    
    client = user_sessions[user_id]["client"]
    phone = user_sessions[user_id]["phone"]
    phone_code_hash = user_sessions[user_id].get("phone_code_hash")
    
    try:
        # Пытаемся войти с полученным кодом
        await client.sign_in(phone, code, phone_code_hash=phone_code_hash)
        
        # Успешная авторизация
        await update.message.reply_text(
            "✅ <b>Успешная авторизация!</b>\n\n"
            "Аккаунт подключен и сессия сохранена. При следующих рассылках не нужно будет вводить данные заново.",
            parse_mode='HTML'
        )
        
        # Переходим к вводу текста сообщения
        await ask_mailing_message(update, context)
        return MAILING_MESSAGE
        
    except SessionPasswordNeededError:
        # Требуется двухфакторная аутентификация
        await update.message.reply_text(
            "🔐 <b>Требуется двухфакторная аутентификация</b>\n\n"
            "На аккаунте включен облачный пароль (2FA).\n"
            "Введите ваш облачный пароль:",
            parse_mode='HTML'
        )
        return MAILING_PASSWORD
        
    except Exception as e:
        error_text = str(e)
        
        if "PHONE_CODE_INVALID" in error_text:
            await update.message.reply_text(
                "❌ <b>Неверный код подтверждения</b>\n\n"
                "Проверьте код и введите снова.",
                parse_mode='HTML'
            )
            return MAILING_CODE
        else:
            await update.message.reply_text(
                f"❌ <b>Ошибка авторизации</b>\n\n{error_text}",
                parse_mode='HTML'
            )
            return ConversationHandler.END

