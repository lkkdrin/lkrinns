    for i in range(30):  # Проверяем 30 раз (каждые 2 секунды = 60 секунд)
        await asyncio.sleep(2)
        
        client, status = await session_manager.check_qr_login(user_id)
        
        if status == 'success' and client:
            me = await client.get_me()
            try:
                await context.bot.send_message(
                    chat_id=user_id,
                    text=(
                        f"✅ <b>Успешный вход!</b>\n\n"
                        f"Аккаунт: @{me.username} (ID: {me.id})\n"
                        f"Сессия сохранена в папке sessions/"
                    ),
                    parse_mode='HTML'
                )
            except:
