# ==================== КЛАСС ДЛЯ СОХРАНЕНИЯ ДАННЫХ ====================
class DataManager:
    """Класс для сохранения и загрузки данных бота"""
    
    def __init__(self, data_file=DATA_FILE):
        self.data_file = data_file
        self.user_data = {}  # Данные пользователей бота
        self.user_wallets = {}  # Привязанные кошельки пользователей
        self.load_data()
    
    def load_data(self):
        """Загружает данные из файла"""
        if os.path.exists(self.data_file):
            try:
                with open(self.data_file, 'rb') as f:
                    data = pickle.load(f)
                    self.user_data = data.get('user_data', {})
                    self.user_wallets = data.get('user_wallets', {})
                logger.info(f"✅ Данные загружены из {self.data_file}")
            except Exception as e:
                logger.error(f"❌ Ошибка загрузки данных: {e}")
                self.user_data = {}
                self.user_wallets = {}
        else:
            logger.info("📁 Файл данных не найден, создаем новые данные")
            self.user_data = {}
            self.user_wallets = {}
    
    def save_data(self):
        """Сохраняет данные в файл"""
        try:
            data = {
                'user_data': self.user_data,
                'user_wallets': self.user_wallets
            }
            with open(self.data_file, 'wb') as f:
                pickle.dump(data, f)
            logger.info(f"✅ Данные сохранены в {self.data_file}")
        except Exception as e:
            logger.error(f"❌ Ошибка сохранения данных: {e}")
    
    def get_user_data(self, user_id: int) -> Dict:
        """Получает данные пользователя"""
        if user_id not in self.user_data:
            self.user_data[user_id] = {
                "authenticated": False, 
                "profits": [], 
                "total_cash": 0,
                "username": None
            }
        return self.user_data[user_id]
    
    def update_user_data(self, user_id: int, data: Dict):
        """Обновляет данные пользователя"""
        self.user_data[user_id] = data
        self.save_data()
    
    def get_wallet(self, user_id: int) -> Optional[str]:
        """Получает кошелек пользователя"""
        return self.user_wallets.get(user_id)
    
    def set_wallet(self, user_id: int, wallet: str):
        """Устанавливает кошелек пользователя"""
        self.user_wallets[user_id] = wallet
        self.save_data()
    
    def add_profit(self, user_id: int, amount: float, profit_type: str):
        """Добавляет профит пользователю"""
        user_data = self.get_user_data(user_id)
        user_data["profits"].append({
            "amount": amount,
            "type": profit_type,
            "date": datetime.now().isoformat()
        })
        user_data["total_cash"] += amount
        self.save_data()

# ==================== КЛАСС ДЛЯ УПРАВЛЕНИЯ РАССЫЛКОЙ ====================
class MailingManager:
    """Класс для управления рассылкой с защитой от бана"""
    
    def __init__(self):
        self.stats = {}  # user_id: {"sent": 0, "hourly": 0, "daily": 0, "last_reset": time.time()}
        self.message_templates = []  # Шаблоны сообщений для вариаций
        
    def add_message_template(self, template: str):
        """Добавляет шаблон сообщения"""
        self.message_templates.append(template)
    
    def get_message_variation(self, original_text: str) -> str:
        """Возвращает вариацию сообщения"""
        if not MESSAGE_VARIATIONS or len(self.message_templates) == 0:
            return original_text
        
        # Небольшие изменения в тексте
        variations = [
            original_text,
            original_text + " 🎁",
            "🎁 " + original_text,
            original_text.replace("!", "."),
            original_text + "\n\nПриятного дня!",
        ]
        
        return random.choice(variations)
    
    def check_limits(self, user_id: int) -> Tuple[bool, str]:
        """Проверяет лимиты на отправку"""
        now = time.time()
        
        if user_id not in self.stats:
            self.stats[user_id] = {
                "sent": 0, 
                "hourly": 0, 
                "daily": 0, 
                "last_hour_reset": now, 
                "last_day_reset": now
            }
        
        stats = self.stats[user_id]
        
        # Сброс часового счетчика
        if now - stats.get("last_hour_reset", now) > 3600:
            stats["hourly"] = 0
            stats["last_hour_reset"] = now
        
        # Сброс дневного счетчика
        if now - stats.get("last_day_reset", now) > 86400:
            stats["daily"] = 0
            stats["last_day_reset"] = now
        
        # Проверка лимитов
        if stats["hourly"] >= MAX_MESSAGES_PER_HOUR:
            return False, f"Достигнут часовой лимит ({MAX_MESSAGES_PER_HOUR} сообщений)"
        
        if stats["daily"] >= MAX_MESSAGES_PER_DAY:
            return False, f"Достигнут дневной лимит ({MAX_MESSAGES_PER_DAY} сообщений)"
        
        return True, "OK"
    
    def increment_counters(self, user_id: int):
        """Увеличивает счетчики отправки"""
        if user_id in self.stats:
            self.stats[user_id]["sent"] += 1
            self.stats[user_id]["hourly"] += 1
            self.stats[user_id]["daily"] += 1
    
    async def get_nft_gift_count(self, client: TelegramClient, user_id: int) -> int:
        """
        Получает количество NFT подарков у пользователя
        Временно используем заглушку
        """
        try:
            # Пытаемся получить информацию о пользователе
            entity = await client.get_entity(user_id)
            
            # Заглушка - возвращаем случайное число
            return random.randint(0, 10)
            
        except Exception as e:
            logger.error(f"Ошибка получения NFT подарков: {e}")
            return 0

# ==================== КЛАСС ДЛЯ СБОРА ПОЛЬЗОВАТЕЛЕЙ ИЗ ГРУПП ====================
class TrafficCollector:
    """Класс для сбора пользователей из групп Telegram"""
    
    def __init__(self):
        self.collected_users = {}  # user_id: {"group": group_name, "users": [], "premium": [], "time": time.time()}
    
    async def get_group_entity(self, client: TelegramClient, group_input: str):
        """
        Получает сущность группы по ссылке или юзернейму
        """
        try:
            # Очищаем входные данные
            group_input = group_input.strip()
            
            # Если это ссылка, извлекаем юзернейм
            if "t.me/" in group_input:
                group_input = group_input.split("t.me/")[-1].split("/")[0]
            
            # Убираем @ если есть
            if group_input.startswith("@"):
                group_input = group_input[1:]
            
            # Получаем сущность
            entity = await client.get_entity(group_input)
            
            return entity
            
        except Exception as e:
            logger.error(f"Ошибка получения группы: {e}")
            return None
    
    async def collect_users_from_group(
        self, 
        client: TelegramClient, 
        group_entity, 
        limit: int = MAX_USERS_PER_GROUP,
        premium_only: bool = PREMIUM_ONLY
    ) -> Tuple[List[str], Dict[str, int]]:
        """
        Собирает пользователей из группы
        Возвращает (список юзернеймов, статистика)
        """
        collected = []
        stats = {
            "total": 0,
            "premium": 0,
            "regular": 0,
            "without_username": 0
        }
        
        try:
            # Получаем участников группы
            offset = 0
            batch_size = 200  # Размер пачки для запроса
            
            while len(collected) < limit:
                try:
                    # Запрашиваем участников
                    participants = await client(GetParticipantsRequest(
                        channel=group_entity,
                        filter=ChannelParticipantsSearch(''),
                        offset=offset,
                        limit=batch_size,
                        hash=0
                    ))
                    
                    if not participants.users:
                        break
                    
                    # Обрабатываем каждого пользователя
                    for user in participants.users:
                        if isinstance(user, User) and not user.bot and not user.deleted:
                            stats["total"] += 1
                            
                            # Проверяем наличие премиума
                            is_premium = getattr(user, 'premium', False)
                            
                            if is_premium:
                                stats["premium"] += 1
                            else:
                                stats["regular"] += 1
                            
                            # Проверяем, нужно ли собирать этого пользователя
                            if premium_only and not is_premium:
                                continue
                            
                            # Получаем юзернейм
                            username = user.username
                            if username:
                                collected.append(f"@{username}")
                            else:
                                stats["without_username"] += 1
                    
                    offset += len(participants.users)
                    
                    # Задержка между запросами
                    await asyncio.sleep(COLLECTION_DELAY)
                    
                    # Если получили меньше, чем запрашивали - достигли конца
                    if len(participants.users) < batch_size:
                        break
                        
                except FloodWaitError as e:
                    wait_time = e.seconds
                    logger.warning(f"Флуд при сборе пользователей, ожидание {wait_time}с")
                    await asyncio.sleep(wait_time + 5)
                    continue
                    
                except Exception as e:
                    logger.error(f"Ошибка при сборе пользователей: {e}")
                    break
            
            # Обрезаем до лимита
            collected = collected[:limit]
            
            return collected, stats
            
        except ChatAdminRequiredError:
            logger.error("Требуются права администратора для получения списка участников")
            return [], {"error": "Требуются права администратора"}
            
        except Exception as e:
            logger.error(f"Ошибка сбора пользователей: {e}")
            return [], {"error": str(e)}
    
    def save_collected_users(self, user_id: int, group_name: str, users: List[str], stats: Dict):
        """Сохраняет собранных пользователей"""
        self.collected_users[user_id] = {
            "group": group_name,
            "users": users,
            "stats": stats,
            "time": time.time()
        }
    
    def get_collected_users(self, user_id: int) -> Optional[Dict]:
        """Получает собранных пользователей"""
        if user_id in self.collected_users:
            # Проверяем, не устарели ли данные (старше 1 часа)
            if time.time() - self.collected_users[user_id]["time"] < 3600:
                return self.collected_users[user_id]
        return None

