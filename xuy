async def mailing_phone(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получение номера телефона для авторизации"""
    phone = update.message.text
    user_id = update.effective_user.id
    
    # Проверяем, есть ли уже сохраненная сессия
    session_file = f"{SESSIONS_DIR}/{user_id}.session"
    
    if os.path.exists(session_file):
        # Загружаем существующую сессию
        await update.message.reply_text("🔄 Обнаружена сохраненная сессия. Подключаюсь...")
        client = TelegramClient(session_file, API_ID, API_HASH)
        await client.connect()
        
        if await client.is_user_authorized():
            user_sessions[user_id] = {"client": client, "phone": phone, "session_file": session_file}
            await update.message.reply_text("✅ Успешное подключение к аккаунту!")
            await ask_mailing_message(update, context)
            return MAILING_MESSAGE
        else:
            os.remove(session_file)  # Удаляем нерабочую сессию
    
    # Новая авторизация
    context.user_data['mailing_phone'] = phone
    
    client = TelegramClient(session_file, API_ID, API_HASH)
    await client.connect()
    
    try:
        # Отправляем код подтверждения
        await client.send_code_request(phone)
        user_sessions[user_id] = {"client": client, "phone": phone, "session_file": session_file}
        
        await update.message.reply_text(
            "📱 На ваш Telegram пришел код подтверждения.\n"
            "Введите код (только цифры):"
        )
        return MAILING_CODE
    except Exception as e:
        await update.message.reply_text(f"❌ Ошибка: {str(e)}")
        return ConversationHandler.END

async def mailing_code(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получение кода подтверждения"""
    code = update.message.text.strip()
    user_id = update.effective_user.id
    
    client = user_sessions[user_id]["client"]
    phone = context.user_data.get('mailing_phone')
    
    try:
        await client.sign_in(phone, code)
        
        # Сохраняем сессию
        await client.disconnect()
        await client.connect()  # Переподключаемся для сохранения
        
        await update.message.reply_text("✅ Успешная авторизация!")
        await ask_mailing_message(update, context)
        return MAILING_MESSAGE
        
    except errors.SessionPasswordNeededError:
        # Запрашиваем облачный пароль (2FA)
        await update.message.reply_text(
            "🔐 На аккаунте включена двухфакторная аутентификация.\n"
            "Введите облачный пароль:"
        )
        return MAILING_PASSWORD
    except Exception as e:
        await update.message.reply_text(f"❌ Ошибка: {str(e)}")
        return ConversationHandler.END

async def mailing_password(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получение облачного пароля (2FA)"""
    password = update.message.text
    user_id = update.effective_user.id
    
    client = user_sessions[user_id]["client"]
    
    try:
