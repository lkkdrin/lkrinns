async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /start"""
    user_id = update.effective_user.id
    
    # Инициализируем данные пользователя, если их нет
    if user_id not in user_data:
        user_data[user_id] = {"authenticated": False, "profits": [], "total_cash": 0}
    
    # Если пользователь уже аутентифицирован, показываем главное меню
    if user_data[user_id]["authenticated"]:
        await show_main_menu(update, context)
        return ConversationHandler.END
    
    # Запрашиваем пароль
    await update.message.reply_text("🔒 Введите пароль для доступа к боту:")
    return ENTER_PASSWORD

async def check_password(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Проверка введенного пароля"""
    user_id = update.effective_user.id
    password = update.message.text
    
    if password == ADMIN_PASSWORD:
        user_data[user_id]["authenticated"] = True
        await update.message.reply_text("✅")
        await show_main_menu(update, context)
        return ConversationHandler.END
    else:
        await update.message.reply_text("❌ Неверный пароль. Попробуйте снова /start")
        return ConversationHandler.END

